{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-v-in-tag": true,
  "packages": {
    ".": {
      "release-type": "simple"
    }
  },
  "changelog-sections": [
    {
      "type": "feat",
      "section": "✨ Features"
    },
    {
      "type": "fix",
      "section": "🐛 Bug Fixes"
    },
    {
      "type": "perf",
      "section": "⚡ Performance"
    },
    {
      "type": "refactor",
      "section": "♻️ Refactoring"
    },
    {
      "type": "docs",
      "section": "📚 Documentation"
    },
    {
      "type": "test",
      "section": "🧪 Tests"
    },
    {
      "type": "build",
      "section": "🏗️ Build"
    },
    {
      "type": "ci",
      "section": "🤖 CI/CD"
    },
    {
      "type": "chore",
      "section": "🧹 Chores",
      "hidden": true
    },
    {
      "type": "style",
      "section": "🎨 Styles",
      "hidden": true
    }
  ]
}